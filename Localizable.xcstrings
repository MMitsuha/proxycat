    "Removes the rule-provider cache, downloaded GeoIP / GeoSite databases, and the downloaded external UI. mihomo re-fetches them on next start. Bundled assets are preserved." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "rule-provider キャッシュ、ダウンロード済みの GeoIP / GeoSite データベース、ダウンロード済みの外部 UI を削除します。次回起動時に mihomo が再取得します。バンドル済みアセットは保持されます。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Удаляет кэш rule-provider, загруженные базы GeoIP / GeoSite и загруженный External UI. mihomo заново загрузит их при следующем запуске. Встроенные ресурсы сохраняются."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "移除 rule-provider 缓存、已下载的 GeoIP / GeoSite 数据库和外部 Web UI。mihomo 会在下次启动时重新获取。内置资源会保留。"
          }
        }
      }
