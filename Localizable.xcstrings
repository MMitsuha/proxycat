    "Stops mihomo's HTTP controller and bundled Web UI from binding. The host app continues to work via its private connection. Applies immediately while connected." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "mihomo の HTTP コントローラーとバンドル済み Web UI のバインドを停止します。ホストアプリはプライベート接続経由で引き続き動作します。接続中でもすぐに適用されます。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Запрещает mihomo привязывать HTTP-контроллер и встроенный Web UI. Основное приложение продолжает работать через приватное соединение. Применяется немедленно при активном подключении."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "阻止 mihomo 的 HTTP 控制器和内置 Web UI 绑定监听。宿主 App 会继续通过私有连接工作。已连接时立即生效。"
          }
        }
      }
