    "Backs up profiles, the active profile, runtime preferences, Auto Connect, and log-retention settings to iCloud Drive. Logs, cache files, usage history, and MITM keys are not included." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プロファイル、アクティブなプロファイル、ランタイム設定、自動接続、ログ保持設定を iCloud Drive にバックアップします。ログ、キャッシュファイル、使用履歴、MITM キーは含まれません。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сохраняет в iCloud Drive профили, активный профиль, настройки среды выполнения, автоподключения и хранения журналов. Сами журналы, файлы кэша, история использования и ключи MITM не включаются."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将配置、当前配置、运行时偏好、自动连接和日志保留设置备份到 iCloud Drive。不包含日志、缓存文件、用量历史和 MITM 密钥。"
          }
        }
      }
    },
    "Backup contains duplicate profile file %@." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
