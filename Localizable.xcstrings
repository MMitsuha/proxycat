    "The local MITM root CA is trusted by iOS. HTTPS rewriting can work for profiles that enable MITM." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ローカル MITM ルート CA は iOS で信頼されています。MITM を有効にしたプロファイルで HTTPS 書き換えを使用できます。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Локальный корневой сертификат MITM является доверенным для iOS. Перезапись HTTPS работает для профилей с включённым MITM."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "本地 MITM 根 CA 已被 iOS 信任。启用 MITM 的配置可以使用 HTTPS 重写。"
          }
        }
      }
    },
