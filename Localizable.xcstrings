    "Both local data and the iCloud backup changed. Choose Back Up Now or Restore from iCloud." : {
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ローカルデータと iCloud バックアップの両方が変更されています。今すぐバックアップするか、iCloud から復元してください。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Локальные данные и резервная копия в iCloud изменились. Выберите «Создать копию» или «Восстановить из iCloud»."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
