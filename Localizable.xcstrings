{
  "sourceLanguage" : "en",
  "strings" : {
    "[truncated — showing last %lld of %lld bytes]\n\n" : {
      "comment" : "Banner prepended to a saved log file's body when only the tail is shown. %1$lld is the number of bytes shown; %2$lld is the file's full size.",
      "extractionState" : "manual",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "［省略済み - 最後の %lld / %lld バイトを表示］\n\n"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[Сокращено: показаны последние %1$lld из %2$lld байт]\n\n"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "[已截断：仅显示末尾 %1$lld / %2$lld 字节]\n\n"
          }
        }
      }
    },
