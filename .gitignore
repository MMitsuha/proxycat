# Xcode
xcuserdata/
*.xcworkspace/xcuserdata
DerivedData/
build/
*.ipa
*.dSYM.zip
*.dSYM

# XcodeGen output (regenerable from project.yml)
ProxyCat.xcodeproj/

# gomobile output (regenerable from libmihomo/ via scripts/build-libmihomo.sh)
Frameworks/

# Compile-time bundled assets (regenerable via `make assets`). The
# directory layout is tracked via .gitkeep so xcodegen sees the folder
# reference; only the downloaded payload is excluded.
BundledAssets/geo/*
!BundledAssets/geo/.gitkeep
BundledAssets/ui/*
!BundledAssets/ui/.gitkeep

# Go module download cache
libmihomo/vendor/

# Go build artifacts
*.test
*.out
coverage.txt

# macOS
.DS_Store

# IDE
.vscode/
.idea/
